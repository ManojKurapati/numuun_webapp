# Namo parent web app — environment variables.
# Local dev: copy to `.env.local`. Production: set in the Vercel dashboard.

# Base URL of the Namo API, including the `/v1` prefix.
# Local:      http://localhost:4000/v1
# Production: https://<your-api-host>/v1
#
# NOTE: NEXT_PUBLIC_* values are inlined at build time — changing this
# requires a redeploy of the web app to take effect.
NEXT_PUBLIC_API_URL=http://localhost:4000/v1

# Public, canonical site URL — used to build absolute Open Graph / Twitter
# image links for social share previews. Set this to your production domain.
# On Vercel it falls back automatically to the project's production URL.
NEXT_PUBLIC_SITE_URL=https://namo-web.vercel.app
