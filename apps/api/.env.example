# Copy to .env and adjust. Never commit the real .env.

NODE_ENV=development
PORT=4000

# PostgreSQL — matches infrastructure/docker/docker-compose.yml
DATABASE_URL=postgresql://namo:namo@localhost:5544/namo?schema=public

# JWT — generate strong random values for any non-local environment
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL_DAYS=30

# Comma-separated list of allowed browser origins
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Log level: trace | debug | info | warn | error
LOG_LEVEL=debug
