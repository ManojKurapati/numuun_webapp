# =============================================================
# NAMO — Environment Variables (template)
# Copy to `.env` and fill in real values. NEVER commit `.env`.
# =============================================================

# ----- App -----
NODE_ENV=production
APP_BASE_URL=https://app.namo.example
API_BASE_URL=https://api.namo.example

# ----- Auth (self-issued, not external) -----
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# OAuth — Google Sign-In
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# OAuth — Apple Sign-In (required for iOS app)
APPLE_OAUTH_TEAM_ID=
APPLE_OAUTH_KEY_ID=
APPLE_OAUTH_PRIVATE_KEY=

# ----- AI / ML -----
# Primary LLM: Anthropic (ASQ extraction, recommendations)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7
# ASR (voice -> text). Whisper via OpenAI; key only needed when voice ships (Phase 2)
OPENAI_API_KEY=
# TTS (question read-aloud). Choose one provider.
ELEVENLABS_API_KEY=

# ----- OCR / ASQ PDF Ingestion: Google Document AI -----
# Path to the GCP service-account JSON file
GOOGLE_APPLICATION_CREDENTIALS=./secrets/gcp-document-ai.json
GCP_PROJECT_ID=
GCP_LOCATION=us
DOCUMENT_AI_PROCESSOR_ID=

# ----- AWS -----
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
S3_BUCKET=namo-prod-assets
# CloudFront signed URLs for video delivery
CLOUDFRONT_DOMAIN=
CLOUDFRONT_KEY_PAIR_ID=
CLOUDFRONT_PRIVATE_KEY=

# ----- Data Stores -----
DATABASE_URL=postgresql://user:password@host:5432/namo
REDIS_URL=redis://host:6379
ELASTICSEARCH_URL=
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=

# ----- Notifications: Push (FCM + APNs) -----
FCM_PROJECT_ID=
# Path to Firebase service-account JSON
FCM_CREDENTIALS=./secrets/fcm-service-account.json
APNS_TEAM_ID=
APNS_KEY_ID=
APNS_PRIVATE_KEY=

# ----- Notifications: SMS (Twilio) -----
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ----- Notifications: Email (SendGrid) -----
SENDGRID_API_KEY=
EMAIL_FROM=no-reply@namo.example

# ----- Observability -----
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=

# ----- CI/CD / Mobile (build-time, store as CI secrets) -----
EXPO_TOKEN=
